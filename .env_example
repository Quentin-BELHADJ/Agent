# Fournisseur de LLM : 'google', 'openai', ou 'ollama'
LLM_PROVIDER=google

# Modèle principal pour les agents
LLM_MODEL=gemini-3.5-flash

# Modèle d'embeddings pour le RAG
LLM_EMBEDDING_MODEL=models/embedding-001

# Clé API du fournisseur (laisser vide ou 'ollama' pour Ollama local)
LLM_API_KEY=votre_cle_api_ici

# URL de base de l'API (optionnel, requis uniquement pour Ollama ou endpoint personnalisé)
# Exemple pour Ollama : http://localhost:11434/v1
LLM_API_BASE=